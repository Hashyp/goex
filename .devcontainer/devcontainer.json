// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/go .
{
	"name": "goex",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/go:2-1.25-trixie",
	"features": {
		"ghcr.io/schlich/devcontainer-features/helix:1": {},
		"./features/ripgrep": {},
		"./features/azurite": {}
		// "ghcr.io/meaningful-ooo/devcontainer-features/fish:2": {}
	},

	"runArgs": [
		"--name=goex"
	],
	"postCreateCommand": "bash -lc 'set -e; touch ~/.bash_aliases; grep -q \"alias goex=\\\"go run ./cmd/goex\\\"\" ~/.bash_aliases || echo \"alias goex=\\\"go run ./cmd/goex\\\"\" >> ~/.bash_aliases; grep -q \"source ~/.bash_aliases\" ~/.bashrc || echo \"source ~/.bash_aliases\" >> ~/.bashrc'",
	"postStartCommand": "bash -lc 'mkdir -p /tmp/azurite; if ! ss -ltn | grep -q \":10000\"; then nohup azurite --location /tmp/azurite --blobHost 0.0.0.0 --queueHost 0.0.0.0 --tableHost 0.0.0.0 >/tmp/azurite/azurite.log 2>&1 < /dev/null & fi'",
	"forwardPorts": [10000, 10001, 10002],
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go"
			]
		}
	},
  
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "go version",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
